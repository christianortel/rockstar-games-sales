# Supabase Postgres connection used by Drizzle.
# Use the pooled connection string in production when deploying to Vercel.
DATABASE_URL="postgres://postgres:[password]@[host]:5432/postgres"

# Optional local runtime target used by smoke and visual checks.
APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Read-only source review route controls.
ADMIN_REVIEW_ENABLED="true"
ADMIN_REVIEW_PASSWORD="change-me"
